# ---------------------------------------------------------------------------
# movie-handler-clients — environment configuration
#
# Copy this file to `.env` and fill in the values. The `.env` file is loaded
# automatically by pydantic-settings at startup and must never be committed.
# ---------------------------------------------------------------------------

# Telegram Bot API token from @BotFather (https://t.me/BotFather).
# How to obtain:
#   1. Open @BotFather in Telegram.
#   2. Send /newbot and follow the prompts (name + username).
#   3. BotFather replies with a token of the form `123456:ABC-DEF...`.
TELEGRAM_BOT_TOKEN=123456:replace-with-real-token

# URL of the running `movie-metadata-mcp` server (streamable-http transport).
# For local/systemd deployment on the same host the default below works.
MOVIE_METADATA_MCP_URL=http://127.0.0.1:8765/mcp

# URL of the running `movie-trailer-mcp` server.
MOVIE_TRAILER_MCP_URL=http://127.0.0.1:8766/mcp

# Bearer token the metadata MCP expects on incoming HTTP requests.
# Must match `MCP_AUTH_TOKEN` in the movie-metadata-mcp service.
MCP_AUTH_TOKEN=change-me-to-a-long-random-string

# SQLite file used to log every MCP request/response pair.
# Logs older than `LOG_TTL_DAYS` are purged lazily on each write.
LOG_DB_PATH=.cache/mcp_traffic.sqlite
LOG_TTL_DAYS=30

# Optional: structlog log level (DEBUG, INFO, WARNING, ERROR).
LOG_LEVEL=INFO
